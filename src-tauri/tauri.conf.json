{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "trafmon",
  "version": "0.1.0",
  "identifier": "com.schweik.trafmon",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "trafmon",
        "width": 200,
        "height": 72,
        "minWidth": 160,
        "minHeight": 56,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
